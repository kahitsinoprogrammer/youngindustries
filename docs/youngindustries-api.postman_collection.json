            "url": {
              "raw": "{{base_url}}/api/v1/accessories",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accessories"
              ]
            },
            "description": "Returns the accessories collection."
          },
          "response": []
        },
        {
          "name": "List Licenses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/licenses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "licenses"
              ]
            },
            "description": "Returns the license collection."
          },
          "response": []
