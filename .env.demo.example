APP_PORT=8000

APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=http://YOUR_SERVER_IP:8000
APP_TIMEZONE=UTC
APP_LOCALE=en-US
MAX_RESULTS=500

PRIVATE_FILESYSTEM_DISK=local
PUBLIC_FILESYSTEM_DISK=local_public

DB_CONNECTION=mysql
DB_DATABASE=snipeit
DB_USERNAME=snipeit
DB_PASSWORD=change-this-db-password
MYSQL_ROOT_PASSWORD=change-this-root-password
DB_PREFIX=null
DB_DUMP_PATH=/usr/bin
DB_DUMP_SKIP_SSL=true
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SSL=false
DB_SSL_IS_PAAS=false
DB_SSL_KEY_PATH=null
DB_SSL_CERT_PATH=null
DB_SSL_CA_PATH=null
DB_SSL_CIPHER=null
DB_SSL_VERIFY_SERVER=null

MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDR=noreply@example.com
MAIL_FROM_NAME=Young Industries Snipe-IT
MAIL_REPLYTO_ADDR=noreply@example.com
MAIL_REPLYTO_NAME=Young Industries Snipe-IT
MAIL_AUTO_EMBED_METHOD=attachment
MAIL_TLS_VERIFY_PEER=true

ALLOW_BACKUP_DELETE=false
ALLOW_DATA_PURGE=false
IMAGE_LIB=gd
BACKUP_ENV=true

SESSION_LIFETIME=12000
EXPIRE_ON_CLOSE=false
ENCRYPT=false
COOKIE_NAME=snipeit_session
COOKIE_DOMAIN=null
SECURE_COOKIES=false
API_TOKEN_EXPIRATION_YEARS=40

APP_TRUSTED_PROXIES=*
ALLOW_IFRAMING=false
REFERRER_POLICY=same-origin
ENABLE_CSP=false
CORS_ALLOWED_ORIGINS=null
ENABLE_HSTS=false

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync
CACHE_PREFIX=snipeit

LOG_CHANNEL=stderr
LOG_MAX_DAYS=10
APP_LOCKED=false
APP_CIPHER=AES-256-CBC
APP_FORCE_TLS=false
