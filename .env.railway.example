PORT=80
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:REPLACE_WITH_A_REAL_GENERATED_KEY
APP_URL=https://REPLACE-WITH-YOUR-RAILWAY-DOMAIN
APP_TIMEZONE=UTC
APP_LOCALE=en-US
APP_TRUSTED_PROXIES=*
APP_FORCE_TLS=true
PRIVATE_FILESYSTEM_DISK=local
PUBLIC_FILESYSTEM_DISK=local_public
IMAGE_LIB=gd

DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_DUMP_SKIP_SSL=true

MAIL_MAILER=log
MAIL_FROM_ADDR=noreply@example.com
MAIL_FROM_NAME=Young Industries Snipe-IT
MAIL_REPLYTO_ADDR=noreply@example.com
MAIL_REPLYTO_NAME=Young Industries Snipe-IT
MAIL_TLS_VERIFY_PEER=true

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync
LOG_CHANNEL=stderr
SECURE_COOKIES=true

ALLOW_BACKUP_DELETE=false
ALLOW_DATA_PURGE=false
